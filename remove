#!/usr/bin/env bash
# Remove skills from local project and global directories

set -eo pipefail

if [[ -n "${BASH_SOURCE[0]:-}" ]]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
else
  SCRIPT_DIR="."
fi
CATALOG="${SCRIPT_DIR}/catalog.tsv"

# Global skill directories
GLOBAL_SKILL_DIRS=(
  "$HOME/.claude/skills"
  "$HOME/.claude/commands"
  "$HOME/.pi/skills"
  "$HOME/.opencode/skills"
  "$HOME/.opencode/command"
  "$HOME/.config/opencode/skills"
  "$HOME/.config/opencode/command"
  "$HOME/.codex/skills"
  "$HOME/.gemini/commands"
  "$HOME/.github/copilot/skills"
)

usage() {
  cat <<'EOF'
Usage: remove [options] <skill-name> [<skill-name> ...]

Remove skills from both local project and global directories.

Options:
  --target PATH          Target directory (default: .)
  --platform PLATFORM    Target platform for removal
  --all                  Remove ALL skills everywhere
  -h, --help             Show this help

Examples:
  remove caveman                    # Remove single skill
  remove caveman grill-me           # Remove multiple
  remove --all                      # Remove everything everywhere
  remove --platform copilot caveman # Remove from Copilot
EOF
}

# Remove from global directories
remove_global() {
  local skill="$1"
  local removed=false
  
  for dir in "${GLOBAL_SKILL_DIRS[@]}"; do
    if [[ -d "$dir" ]]; then
      while IFS= read -r -d '' item; do
        local basename_item
        basename_item=$(basename "$item")
        if [[ "$basename_item" =~ ^${skill}$ ]] || [[ "$basename_item" =~ ^${skill}- ]]; then
          rm -rf "$item"
          echo "    ✓ Removed from $dir: $basename_item"
          removed=true
        fi
      done < <(find "$dir" -maxdepth 1 -mindepth 1 -print0 2>/dev/null || true)
    fi
  done
  
  $removed
}

# Remove npm global packages
remove_npm_global() {
  local pattern="$1"
  local removed=false
  
  if command -v npm &> /dev/null; then
    local npm_pkgs
    npm_pkgs=$(npm list -g --depth=0 2>/dev/null | grep -E "^├─|^└─" | sed 's/^[├└─│ ]*//' | grep -i "$pattern" | sed 's/@[^@]*$//' || true)
    
    if [[ -n "$npm_pkgs" ]]; then
      echo "$npm_pkgs" | while read pkg; do
        [[ -n "$pkg" ]] && npm uninstall -g "$pkg" 2>/dev/null && echo "    ✓ Removed npm global: $pkg" && removed=true
      done
    fi
  fi
  
  $removed
}

# Parse arguments
TARGET="."
PLATFORM=""
REMOVE_ALL=false
SKILLS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target) TARGET="$2"; shift 2 ;;
    --platform) PLATFORM="$2"; shift 2 ;;
    --all) REMOVE_ALL=true; shift ;;
    -h|--help) usage; exit 0 ;;
    --*) echo "Error: unknown flag $1" >&2; usage >&2; exit 1 ;;
    *) SKILLS+=("$1"); shift ;;
  esac
done

mkdir -p "$TARGET"
TARGET="$(cd "$TARGET" && pwd)"

# --all: nuke everything
if [[ "$REMOVE_ALL" == true ]]; then
  echo "Removing ALL skills from $TARGET"
  
  # Local
  if (cd "$TARGET" && npx skills remove --all --yes < /dev/null 2>&1); then
    echo "  ✓ All local skills removed"
  else
    echo "  ⚠ Local removal failed or none found"
  fi
  
  # Global
  echo "Removing global skills..."
  for dir in "${GLOBAL_SKILL_DIRS[@]}"; do
    if [[ -d "$dir" ]]; then
      rm -rf "$dir"/*
      echo "  ✓ Cleared $dir"
    fi
  done
  
  echo ""
  echo "✓ Removal complete"
  exit 0
fi

# Check for skills
if [[ ${#SKILLS[@]} -eq 0 ]]; then
  echo "Error: remove requires a SKILL name (or --all)" >&2
  usage >&2
  exit 1
fi

echo "Removing skills from $TARGET"

for skill in "${SKILLS[@]}"; do
  echo ""
  echo "→ $skill"
  
  # 1. Local removal
  remove_cmd=""
  
  # Look up in catalog
  if [[ -f "$CATALOG" ]]; then
    remove_cmd=$(awk -F'\t' -v n="$skill" '$1==n && NF>=9 && $9!="" && $9!="-" {print $9; exit}' "$CATALOG" 2>/dev/null || true)
    
    if [[ -z "$remove_cmd" ]]; then
      local install_cmd
      install_cmd=$(awk -F'\t' -v n="$skill" '$1==n {print $7; exit}' "$CATALOG" 2>/dev/null || true)
      
      if [[ "$install_cmd" == "npx skills add"* ]]; then
        remove_cmd="npx skills remove $skill --yes"
      elif [[ "$install_cmd" == "npm install -g"* ]]; then
        local pkg="${install_cmd#npm install -g }"
        pkg="${pkg#"${pkg%%[![:space:]]*}"}"
        pkg="${pkg%"${pkg##*[![:space:]]}"}"
        remove_cmd="npm uninstall -g $pkg"
      elif [[ "$install_cmd" == "pi install npm:"* ]]; then
        local pkg="${install_cmd#pi install }"
        pkg="${pkg#"${pkg%%[![:space:]]*}"}"
        pkg="${pkg%"${pkg##*[![:space:]]}"}"
        remove_cmd="pi remove $pkg"
      fi
    fi
  fi
  
  # Platform-specific override
  if [[ "$PLATFORM" == "copilot" ]]; then
    if command -v copilot &> /dev/null; then
      remove_cmd="copilot -- plugin uninstall $skill"
    else
      remove_cmd="gh copilot -- plugin uninstall $skill"
    fi
  fi
  
  # Fallback
  [[ -z "$remove_cmd" ]] && remove_cmd="npx skills remove $skill --yes"
  
  echo "  Local: $remove_cmd"
  if (cd "$TARGET" && eval "$remove_cmd" < /dev/null 2>&1); then
    echo "    ✓ Removed from local project"
  else
    echo "    ℹ Not found in local project (or already removed)"
  fi
  
  # 2. Global removal
  echo "  Global directories..."
  if remove_global "$skill"; then
    : # Removed items already printed
  else
    echo "    ℹ Not found in global directories"
  fi
  
  # 3. NPM global
  echo "  NPM global packages..."
  if remove_npm_global "$skill"; then
    : # Removed packages already printed
  else
    echo "    ℹ No matching npm global packages"
  fi
done

echo ""
echo "✓ Removal complete"
